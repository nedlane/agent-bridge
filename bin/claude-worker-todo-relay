#!/usr/bin/env bash
# Relay a Claude Code worker's live task checklist to Discord — no Codex, no
# model calls, no tokens. Registered as a PostToolUse hook on
# TodoWrite|TaskCreate|TaskUpdate (see docs/agent-control-plane.md), so every
# todo-list update and every task create/edit/complete/delete lands as
# checkboxes in the Discord channel behind the webhook.
#
# Hook input (JSON on stdin): {session_id, cwd, tool_name, tool_input}.
# TodoWrite carries the full list in tool_input.todos; the Task tools only
# carry a delta, so the full list is re-read from the session's task dir
# (~/.claude/tasks/<session-id>/, override with $CLAUDE_TASKS_DIR).
#
# Behaviour:
#   - Only fires for orchestrated workers (claude-worker sets $CLAUDE_WORKER);
#     manual `cl` sessions stay quiet. CLAUDE_WORKER_TODO_ALL=1 relays all.
#   - Workers started with --chat post into their repo channel through the
#     claude-bridge (a signed localhost event); others fall back to the
#     plain Discord webhook, which can only reach the main channel.
#   - Webhook URL is read from a chmod-600 file, never from env, and never
#     printed or logged: ~/.config/claude-workers/discord-webhook (override
#     with $CLAUDE_WORKERS_DISCORD_WEBHOOK_FILE).
#   - Identical checklists are deduped via a hash in the worker's state dir.
#   - Always exits 0: a relay problem must never break the Claude session.
set -uo pipefail

WEBHOOK_FILE="${CLAUDE_WORKERS_DISCORD_WEBHOOK_FILE:-${XDG_CONFIG_HOME:-$HOME/.config}/claude-workers/discord-webhook}"
BRIDGE_CFG="${CLAUDE_WORKERS_BRIDGE_WEBHOOK_FILE:-${XDG_CONFIG_HOME:-$HOME/.config}/claude-workers/bridge-webhook}"
STATE_ROOT="${CLAUDE_WORKERS_STATE:-${XDG_STATE_HOME:-$HOME/.local/state}/claude-workers}"

# bridge_send <chat> <content> — signed claude.worker.send event to the
# local claude-bridge, which posts into the mapped Discord channel.
bridge_send() {
  local url secret body sig
  [[ -r "$BRIDGE_CFG" ]] || return 1
  url="$(sed -n 's/^BRIDGE_WEBHOOK_URL=//p' "$BRIDGE_CFG" | head -1)"
  secret="$(sed -n 's/^BRIDGE_WEBHOOK_SECRET=//p' "$BRIDGE_CFG" | head -1)"
  [[ -n "$url" && -n "$secret" ]] || return 1
  body="$(CHAT="$1" CONTENT="$2" python3 -c '
import json, os
print(json.dumps({"event_type": "claude.worker.send",
                  "chat": os.environ["CHAT"],
                  "content": os.environ["CONTENT"]}))' 2>/dev/null)" || return 1
  [[ -n "$body" ]] || return 1
  sig="$(printf '%s' "$body" | SECRET="$secret" python3 -c '
import hashlib, hmac, os, sys
print(hmac.new(os.environ["SECRET"].encode(), sys.stdin.buffer.read(),
               hashlib.sha256).hexdigest())' 2>/dev/null)" || return 1
  curl -fsS -m 10 -H 'Content-Type: application/json' \
    -H "X-Webhook-Signature: $sig" -d "$body" "$url" >/dev/null 2>&1
}

worker="${CLAUDE_WORKER:-}"
if [[ -z "$worker" && "${CLAUDE_WORKER_TODO_ALL:-0}" != 1 ]]; then
  exit 0
fi

# The worker's originating chat thread, if it was started with --chat.
chat=""
if [[ -n "$worker" ]]; then
  chat="$(sed -n 's/^chat=//p' "$STATE_ROOT/$worker/meta" 2>/dev/null | head -1)"
fi

# Parse the hook input and render the checklist as plain text. The hook JSON
# is captured before the heredoc below, which would otherwise consume stdin.
# Prints nothing on bad/empty input.
hook_json="$(cat 2>/dev/null || true)"
content="$(HOOK_JSON="$hook_json" python3 - "$worker" <<'PY' 2>/dev/null
import json, os, sys

import glob

worker = sys.argv[1] or "session"
try:
    hook = json.loads(os.environ.get("HOOK_JSON", ""))
except Exception:
    sys.exit(0)

items = []  # (status, text)
if hook.get("tool_name") == "TodoWrite":
    for t in (hook.get("tool_input") or {}).get("todos") or []:
        status = t.get("status", "pending")
        text = t.get("activeForm") if status == "in_progress" else t.get("content")
        items.append((status, text or "?"))
else:
    # TaskCreate/TaskUpdate: the tool input is only a delta, so render the
    # whole checklist from the session's on-disk task list
    # (~/.claude/tasks/<session-id>/<n>.json).
    tasks_dir = os.environ.get("CLAUDE_TASKS_DIR") or os.path.join(
        os.path.expanduser("~"), ".claude", "tasks", hook.get("session_id") or "-")
    tasks = []
    for path in glob.glob(os.path.join(tasks_dir, "*.json")):
        try:
            with open(path) as fh:
                tasks.append(json.load(fh))
        except Exception:
            pass
    tasks.sort(key=lambda t: (not str(t.get("id", "")).isdigit(),
                              int(t["id"]) if str(t.get("id", "")).isdigit() else 0,
                              str(t.get("id", ""))))
    for t in tasks:
        if t.get("status") in ("deleted", "cancelled"):
            continue
        items.append((t.get("status", "pending"), t.get("subject") or "?"))

if not items:
    sys.exit(0)

mark = {"completed": "✅", "in_progress": "▶️", "pending": "⬜"}
lines = [f"**worker:{worker}** — `{os.path.basename(hook.get('cwd') or '') or '?'}`"]
for status, text in items:
    lines.append(f"{mark.get(status, '⬜')} {text}")

content = "\n".join(lines)
if len(content) > 1900:  # Discord caps messages at 2000 chars
    content = content[:1900] + "\n…"
print(content)
PY
)"
[[ -n "$content" ]] || exit 0

# Dedupe: skip if this exact checklist was already posted for this worker.
state_dir="$STATE_ROOT/${worker:-_all}"
mkdir -p "$state_dir" 2>/dev/null || exit 0
hash="$(printf '%s' "$content" | cksum)"
last_file="$state_dir/todo-relay.last"
[[ -f "$last_file" && "$(cat "$last_file")" == "$hash" ]] && exit 0

# Chat-bound workers post into their repo channel via the bridge.
if [[ -n "$chat" ]]; then
  if bridge_send "$chat" "$content"; then
    printf '%s' "$hash" > "$last_file"
  fi
  exit 0
fi

# Fallback: plain webhook POST to the main channel.
[[ -r "$WEBHOOK_FILE" ]] || exit 0
webhook="$(head -1 "$WEBHOOK_FILE")"
[[ -n "$webhook" ]] || exit 0
payload="$(MSG="$content" python3 -c 'import json,os; print(json.dumps({"content": os.environ["MSG"]}))' 2>/dev/null)"
[[ -n "$payload" ]] || exit 0
if curl -fsS -m 10 -H 'Content-Type: application/json' \
     -d "$payload" "$webhook" >/dev/null 2>&1; then
  printf '%s' "$hash" > "$last_file"
fi
exit 0
