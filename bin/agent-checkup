#!/usr/bin/env bash
# Readiness check for the local agent control plane:
#   Discord -> claude-bridge -> claude-worker -> tmux -> claude-launch ->
#   interactive Claude Code (Claude subscription; no LLM in the bridge).
#
# Verifies the pieces that can be checked from this machine — Claude Code on
# its *subscription* auth path (never API-key/provider billing), tmux, the
# bridge runtime and credentials, worker tooling linked, state dir writable —
# and prints explicit manual checks for everything that can't (Discord
# intents, live auth). Reads auth files for shape only; never prints their
# values. Exits 1 if anything FAILs.
set -uo pipefail

pass_n=0 warn_n=0 fail_n=0
pass() { echo "PASS  $*"; ((pass_n++)) || true; }
warn() { echo "WARN  $*"; ((warn_n++)) || true; }
fail() { echo "FAIL  $*"; ((fail_n++)) || true; }

echo "== agent control plane checkup =="

# --- tmux ---------------------------------------------------------------------
if command -v tmux >/dev/null 2>&1; then
  pass "tmux installed ($(command -v tmux))"
else
  fail "tmux not found — workers cannot run (install tmux)"
fi

# --- Claude Code ----------------------------------------------------------------
if command -v claude >/dev/null 2>&1; then
  pass "claude installed ($(claude --version 2>/dev/null | head -1 || echo 'version unknown'))"
  if [[ -f "$HOME/.claude/.credentials.json" ]] \
     || grep -q '"oauthAccount"' "$HOME/.claude.json" 2>/dev/null; then
    pass "claude interactive (subscription) credentials present"
  else
    warn "claude has no interactive credentials — run \`claude\` once and /login with your Claude subscription"
  fi
else
  fail "claude not found — install Claude Code and run \`claude\` to log in"
fi

# --- forbidden API/provider env --------------------------------------------------
for var in ANTHROPIC_API_KEY ANTHROPIC_AUTH_TOKEN ANTHROPIC_BASE_URL \
           CLAUDE_CODE_USE_BEDROCK CLAUDE_CODE_USE_VERTEX; do
  if [[ -n "${!var:-}" ]]; then
    warn "$var is set — would push Claude Code onto API/provider billing (claude-launch strips it, but find and remove the source)"
  fi
done

# --- claude-bridge (Discord <-> worker pipe) ---------------------------------------
bridge_cfg="${CLAUDE_BRIDGE_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/claude-bridge/config.json}"
token_file="${CLAUDE_BRIDGE_TOKEN_FILE:-${XDG_CONFIG_HOME:-$HOME/.config}/claude-workers/discord-bot-token}"
if python3 -c 'import discord' 2>/dev/null; then
  pass "discord.py importable (bridge runtime dependency)"
else
  fail "discord.py not importable — run: pip3 install --user discord.py"
fi
if [[ -s "$token_file" ]]; then
  pass "Discord bot token file present ($token_file)"
else
  fail "no Discord bot token ($token_file) — the bridge cannot log in"
fi
if [[ -r "$bridge_cfg" ]]; then
  pass "bridge config present ($bridge_cfg)"
else
  warn "no bridge config ($bridge_cfg) — no repo channels are mapped yet (/addrepo, or see the claude-bridge skill)"
fi
if systemctl --user is-active claude-bridge >/dev/null 2>&1; then
  pass "claude-bridge service active"
else
  warn "claude-bridge service not active — systemctl --user enable --now claude-bridge"
fi

# --- worker tooling ----------------------------------------------------------------
for tool in claude-launch claude-worker claude-worker-todo-relay \
            claude-worker-done-relay claude-bridge bridge-ctl discord-notify \
            agent-checkup; do
  if command -v "$tool" >/dev/null 2>&1; then
    pass "$tool on PATH ($(command -v "$tool"))"
  else
    fail "$tool not on PATH — run scripts/link.sh (links it into ~/.local/bin)"
  fi
done

state_root="${CLAUDE_WORKERS_STATE:-${XDG_STATE_HOME:-$HOME/.local/state}/claude-workers}"
if mkdir -p "$state_root" 2>/dev/null && [[ -w "$state_root" ]]; then
  pass "worker state dir writable ($state_root)"
else
  fail "worker state dir not writable ($state_root)"
fi

webhook_file="${CLAUDE_WORKERS_DISCORD_WEBHOOK_FILE:-${XDG_CONFIG_HOME:-$HOME/.config}/claude-workers/discord-webhook}"
if [[ -r "$webhook_file" ]]; then
  pass "Discord todo-relay webhook file present ($webhook_file)"
else
  warn "no Discord webhook file ($webhook_file) — the todo relay will stay silent until you create it (see docs/agent-control-plane.md)"
fi

bridge_webhook_file="${CLAUDE_WORKERS_BRIDGE_WEBHOOK_FILE:-${XDG_CONFIG_HOME:-$HOME/.config}/claude-workers/bridge-webhook}"
if [[ -r "$bridge_webhook_file" ]]; then
  pass "bridge event-listener credentials present ($bridge_webhook_file)"
else
  warn "no bridge webhook file ($bridge_webhook_file) — worker replies cannot reach Discord (see docs/agent-control-plane.md)"
fi

# --- manual checks ------------------------------------------------------------------
cat <<'MANUAL'

== manual checks (cannot be verified automatically) ==
 - Claude subscription path: inside a `claude` session run /status — the
   account line should show your Claude subscription, not an API key.
 - Hooks: confirm ~/.claude/settings.json registers claude-worker-todo-relay
   (PostToolUse: TodoWrite|TaskCreate|TaskUpdate) and claude-worker-done-relay
   (Stop) — snippets in docs/agent-control-plane.md.
 - Discord intents: the bot needs Message Content (and Manage Channels, and
   the applications.commands scope for the /addrepo slash command) in the developer portal.
 - First smoke test: map a repo with /addrepo, message its channel, and
   confirm the worker's reply lands back in the same channel.
MANUAL

echo
echo "== summary: $pass_n passed, $warn_n warnings, $fail_n failures =="
(( fail_n == 0 )) || exit 1
