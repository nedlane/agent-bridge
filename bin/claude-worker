#!/usr/bin/env bash
# Manage persistent tmux-backed interactive Claude Code workers (desktop-only
# half of the local agent control plane: Discord/OpenClaw/Hermes -> Codex ->
# claude-worker -> tmux -> claude-launch -> interactive Claude Code).
#
# Each worker is a detached tmux session named "cw-<name>" running
# shared/bin/claude-launch, so it uses the normal interactive subscription
# auth path — never an Anthropic API key or Bedrock/Vertex billing. The Claude
# session title is "<host> / worker:<name>", keeping orchestrated workers
# distinguishable (for Codex and in the claude.ai session list) from manual
# `cl` sessions, whose titles use the directory name.
#
#   claude-worker start <name> [--dir DIR] [--harness claude|codex] [--resume]
#                              [-- engine args...]
#                                            # blocks until the worker is ready
#                                            # --harness picks the engine
#                                            #   (codex runs in YOLO mode)
#   claude-worker send  <name> <text|->     # '-' reads the message from stdin
#   claude-worker wait  <name> [--for TEXT] [--timeout SECS]
#                                            # block until idle (or TEXT shows)
#   claude-worker read  <name> [lines]      # capture the worker's screen
#   claude-worker key   <name> <key>...     # send raw keys (Escape, C-c, …)
#   claude-worker list
#   claude-worker status <name>
#   claude-worker restart <name>            # same name, same recorded dir
#   claude-worker stop <name>
#
# State (no secrets) lives under ${XDG_STATE_HOME:-~/.local/state}/claude-workers/<name>/:
#   meta        flat key=value: name, session, dir, label, created, log
#   output.log  raw terminal output (tmux pipe-pane), append-only
# Orchestrators should read those files instead of shell state.
set -euo pipefail

STATE_ROOT="${CLAUDE_WORKERS_STATE:-${XDG_STATE_HOME:-$HOME/.local/state}/claude-workers}"
SESSION_PREFIX="cw-"
# Delay between pasting a message and pressing Enter, so the TUI registers the
# paste first. Tunable for tests.
SEND_DELAY="${CLAUDE_WORKER_SEND_DELAY:-0.4}"
# Polling cadence for wait/start readiness, and how long start blocks for the
# worker to boot to an idle prompt.
POLL="${CLAUDE_WORKER_POLL:-4}"
START_TIMEOUT="${CLAUDE_WORKER_START_TIMEOUT:-90}"

usage() {
  sed -n '/^#   claude-worker/,/^# Orchestrators/p' "$0" | sed 's/^# \{0,2\}//'
}

die() {
  echo "claude-worker: $*" >&2
  exit 1
}

require_name() {
  [[ -n "${1:-}" ]] || die "worker name required (see claude-worker --help)"
  [[ "$1" =~ ^[A-Za-z0-9][A-Za-z0-9_-]*$ ]] \
    || die "invalid worker name '$1' (letters, digits, '-', '_' only)"
}

session_for() { printf '%s%s' "$SESSION_PREFIX" "$1"; }

# tmux's -t matching is prefix-fuzzy; '=' forces an exact session match.
# Commands that take a target-PANE need the trailing ':' ("=name:") — bare
# "=name" only resolves for target-session commands on tmux 3.2.
alive() { tmux has-session -t "=$(session_for "$1")" 2>/dev/null; }
pane_for() { printf '=%s:' "$(session_for "$1")"; }

meta_get() { # meta_get <name> <key>
  sed -n "s/^$2=//p" "$STATE_ROOT/$1/meta" 2>/dev/null | head -1
}

screen_of() { tmux capture-pane -p -t "$(pane_for "$1")" -S -50 2>/dev/null || true; }

# These readiness predicates match BOTH harnesses with a superset of markers,
# so the orchestration stays engine-agnostic without threading a harness flag
# through every check. The strings are distinct enough not to collide:
#   Claude Code — "esc to interrupt" while a turn works, "Compacting" mid
#     auto-compaction; idle prompt char "❯".
#   Codex       — "Working (Ns • esc to interrupt)" while a turn works (note it
#     also carries "esc to interrupt"); idle prompt char "›".
is_busy() { grep -qE "esc to interrupt|Compacting|Working \(" <<<"$1"; }
# A blocking dialog awaiting input is always the BOTTOM-most thing on screen, so
# the dialog checks look only at the tail of the capture. This matters after
# dismissal: the dialog text lingers in tmux scrollback, and Codex's compact
# boot keeps it inside the capture window (Claude's longer boot scrolls it out),
# so a full-screen grep would keep matching a dialog that's already gone and the
# worker would never read as ready.
dialog_tail() { tail -15 <<<"$1"; }
# First boot in a new directory stops at the folder-trust dialog. Both engines
# use the phrase "Do you trust…" (Claude: "…this folder?"; Codex: "…the
# contents of this directory?"), so the shared substring catches both.
is_trust_dialog() { grep -qE "trust this folder|Do you trust" <<<"$(dialog_tail "$1")"; }
# A large Claude session resumed with --continue first asks how to resume
# (summary vs full); its menu cursor is also a "❯", so it must not be mistaken
# for the idle input prompt — it's a blocking dialog to dismiss. Codex resume
# has no such dialog, so this simply never matches on the Codex path.
is_resume_dialog() { grep -qE "Resume from summary|Resume full session" <<<"$(dialog_tail "$1")"; }
# Idle: the input prompt (Claude "❯" or Codex "›") is on screen and nothing is
# running or blocking.
is_ready() {
  grep -qE "❯|›" <<<"$1" \
    && ! is_busy "$1" && ! is_trust_dialog "$1" && ! is_resume_dialog "$1"
}

# The input box is the LAST screen line beginning with the prompt char (Claude
# "❯", Codex "›"). A submitted message also echoes as a "prompt ..." history
# line above it, so tail -1 is what isolates the live box.
input_line() { screen_of "$1" | grep -E '^❯|^›' | tail -1 || true; }
# A multi-line (or long) bracketed paste does NOT echo its text into the box —
# the composer collapses it to a chip like "❯ [Pasted text #1 +17 lines]". So
# submission has to be judged by the chip's presence/absence, not by matching
# the message text back on the prompt line.
is_paste_chip() { grep -qE '\[Pasted text #[0-9]+' <<<"$1"; }

# wait_until <name> <timeout> [text] — poll the worker's screen until it is
# idle at its prompt (or [text] appears). Auto-dismisses the startup dialogs
# that gate the prompt: the folder-trust dialog (the orchestrator chose the
# directory deliberately via --dir) and the resume-mode dialog on a large
# --continue (Enter takes the pre-highlighted "Resume from summary" default).
#
# The done-condition must hold on TWO consecutive polls: right after a send
# there is a short window where the message is echoed (marker visible) but
# the busy indicator hasn't appeared yet — a single look reports done while
# the task hasn't even started. A second look one poll later sees the busy
# indicator instead, and the echoed marker alone never counts while busy.
# Returns 0 ready/matched, 1 worker died, 2 timeout.
wait_until() {
  local name="$1" timeout="$2" for_text="${3:-}" started=$SECONDS screen done_now stable=0
  while :; do
    alive "$name" || { echo "claude-worker: worker '$name' died while waiting" >&2; return 1; }
    screen="$(screen_of "$name")"
    done_now=0
    if is_trust_dialog "$screen" || is_resume_dialog "$screen"; then
      tmux send-keys -t "$(pane_for "$name")" Enter
    elif [[ -n "$for_text" ]]; then
      if ! is_busy "$screen" && grep -qF -- "$for_text" <<<"$screen"; then
        done_now=1
      fi
    elif is_ready "$screen"; then
      done_now=1
    fi
    if (( done_now )); then
      (( stable >= 1 )) && return 0
      stable=$((stable + 1))
    else
      stable=0
    fi
    (( SECONDS - started >= timeout )) && return 2
    sleep "$POLL"
  done
}

cmd_start() {
  require_name "${1:-}"
  local name="$1"
  shift
  local dir="$PWD" chat="" harness="claude" resume=0 extra=()
  while (($#)); do
    case "$1" in
      --dir)    dir="${2:?--dir needs a value}"; shift 2 ;;
      --dir=*)  dir="${1#--dir=}"; shift ;;
      # Originating chat thread (hermes send target, e.g.
      # "discord:<channel_id>:<thread_id>"). Relays and completion events for
      # this worker go back to that thread instead of the home channel, and
      # --chat is what opts the worker into push-on-done events.
      --chat)   chat="${2:?--chat needs a value}"; shift 2 ;;
      --chat=*) chat="${1#--chat=}"; shift ;;
      # Which engine drives this worker: "claude" (default) or "codex". The
      # bridge passes it from the channel's mapped harness; it is recorded in
      # meta so restart/relays know the engine without re-reading bridge config.
      --harness)   harness="${2:?--harness needs a value}"; shift 2 ;;
      --harness=*) harness="${1#--harness=}"; shift ;;
      # Resume the prior conversation. Engine-specific: Claude gets --continue,
      # Codex gets `resume --last`. Centralized here so the bridge just says
      # "resume" and each launcher does the right thing.
      --resume) resume=1; shift ;;
      --)       shift; extra=("$@"); break ;;
      *)        die "unknown start option '$1'" ;;
    esac
  done
  [[ "$chat" =~ ^[^[:space:]]*$ ]] || die "invalid --chat target '$chat'"
  [[ "$harness" == claude || "$harness" == codex ]] \
    || die "invalid --harness '$harness' (claude or codex)"
  [[ -d "$dir" ]] || die "no such directory: $dir"
  alive "$name" && die "worker '$name' is already running (try: claude-worker restart $name)"

  local session state launcher launcher_args=()
  session="$(session_for "$name")"
  state="$STATE_ROOT/$name"
  mkdir -p "$state"

  # Pick the engine launcher. Both live in this repo's bin/ (symlinked by
  # scripts/link.sh); claude-launch may also be provided by the dotfiles tree.
  if [[ "$harness" == codex ]]; then
    command -v codex >/dev/null 2>&1 || die "codex CLI not found on PATH"
    launcher="$(command -v codex-launch || true)"
    [[ -n "$launcher" ]] || launcher="$(dirname "$(readlink -f "$0")")/codex-launch"
    [[ -x "$launcher" ]] || die "codex-launch not found (run scripts/link.sh)"
    # Codex resume is a launcher flag; the Discord protocol is injected by the
    # bridge as the worker's first message, not a launch flag.
    (( resume )) && launcher_args+=(--resume)
  else
    command -v claude >/dev/null 2>&1 || die "claude CLI not found on PATH"
    launcher="$(command -v claude-launch || true)"
    [[ -n "$launcher" ]] || launcher="${DOTFILES_DIR:-$HOME/dotfiles}/shared/bin/claude-launch"
    [[ -x "$launcher" ]] || die "claude-launch not found (run scripts/link.sh)"
    # Claude resumes with --continue, passed through claude-launch to claude.
    (( resume )) && extra=(--continue ${extra[@]+"${extra[@]}"})
  fi

  # One shell-safe command string: tmux joins its trailing args with spaces,
  # so each word is %q-quoted. CLAUDE_WORKER marks the session as an
  # orchestrated worker for hooks/relays (Discord todo + done relays) and for
  # discord-notify's channel auto-targeting — engine-agnostic, so a Codex
  # worker gets the same outbound messaging. A tmux session inherits the tmux
  # SERVER's env, not this caller's, so any var the engine needs is forwarded
  # explicitly here: CODEX_HOME (usually unset -> default ~/.codex; set to point
  # a worker at an alternate Codex home, e.g. for tests) rides along when set.
  local env_prefix=(env "CLAUDE_WORKER=$name")
  [[ -n "${CODEX_HOME:-}" ]] && env_prefix+=("CODEX_HOME=$CODEX_HOME")
  local cmd
  cmd="$(printf '%q ' "${env_prefix[@]}" "$launcher" \
    --label "worker:$name" ${launcher_args[@]+"${launcher_args[@]}"} \
    ${extra[@]+"${extra[@]}"})"
  tmux new-session -d -s "$session" -c "$dir" "$cmd"
  tmux pipe-pane -t "=$session:" -o "cat >> $(printf '%q' "$state/output.log")"

  {
    echo "name=$name"
    echo "session=$session"
    echo "dir=$dir"
    echo "harness=$harness"
    echo "label=worker:$name"
    if [[ -n "$chat" ]]; then echo "chat=$chat"; fi
    echo "created=$(date '+%Y-%m-%dT%H:%M:%S%z')"
    echo "log=$state/output.log"
  } > "$state/meta"

  echo "started worker '$name'"
  echo "  tmux:   tmux attach -t $session"
  echo "  dir:    $dir"
  echo "  log:    $state/output.log"

  # Block until the worker is at its idle prompt (accepting the folder-trust
  # dialog on the way), so the caller can send work immediately after.
  if wait_until "$name" "$START_TIMEOUT"; then
    echo "  state:  ready"
  else
    case $? in
      1) die "worker '$name' exited during startup (check $state/output.log)" ;;
      *) echo "  state:  still starting after ${START_TIMEOUT}s — check with: claude-worker read $name" >&2 ;;
    esac
  fi
}

cmd_wait() {
  require_name "${1:-}"
  local name="$1"
  shift
  local for_text="" timeout=600
  while (($#)); do
    case "$1" in
      --for)       for_text="${2:?--for needs a value}"; shift 2 ;;
      --for=*)     for_text="${1#--for=}"; shift ;;
      --timeout)   timeout="${2:?--timeout needs a value}"; shift 2 ;;
      --timeout=*) timeout="${1#--timeout=}"; shift ;;
      *)           die "unknown wait option '$1'" ;;
    esac
  done
  [[ "$timeout" =~ ^[0-9]+$ ]] || die "timeout must be a number, got '$timeout'"
  alive "$name" || die "worker '$name' is not running"
  if wait_until "$name" "$timeout" "$for_text"; then
    echo "ready"
    return
  fi
  case $? in
    1) exit 1 ;;
    *) echo "claude-worker: timed out after ${timeout}s; current screen:" >&2
       screen_of "$name" | grep -v '^[[:space:]]*$' | tail -15 >&2
       exit 2 ;;
  esac
}

cmd_send() {
  require_name "${1:-}"
  local name="$1"
  shift
  local typed=0 text=""
  while (($#)); do
    case "$1" in
      --type) typed=1; shift ;;  # typed keystrokes (slash commands), not a paste
      *)      text="$1"; shift ;;
    esac
  done
  [[ -n "$text" ]] || die "usage: claude-worker send <name> [--type] <text|->"
  alive "$name" || die "worker '$name' is not running"
  [[ "$text" == "-" ]] && text="$(cat)"
  local pane
  pane="$(pane_for "$name")"
  # Stage the message as a bracketed paste so multi-line text stays one
  # message instead of submitting at the first newline (--type instead sends
  # literal keystrokes so the TUI sees a typed /slash-command). Submission is
  # then verified in two phases against the input box (input_line):
  #   Phase 1 — confirm the message LANDED: the box shows the probe text
  #             (typed / single-line paste) OR a paste chip (multi-line paste,
  #             whose text never echoes). An empty box means a booting/
  #             compacting TUI silently dropped the input — never a success.
  #   Phase 2 — settle, then submit and confirm it LEFT the box (no chip, no
  #             probe). The TUI can swallow a key at a turn boundary, so retry.
  local probe attempt line landed=0
  probe="${text%%$'\n'*}"
  probe="${probe:0:40}"
  if (( typed )); then
    tmux send-keys -t "$pane" -l "$text"
  else
    # Clear any leftover paste chip first so a re-send never stacks pastes
    # ("[Pasted #1][Pasted #2]"). A single Ctrl-C clears a non-empty composer;
    # it only begins Claude's exit countdown when the box is ALREADY empty, so
    # gating on a visible chip keeps this safe (never the double Ctrl-C that
    # quits Claude Code).
    if is_paste_chip "$(input_line "$name")"; then
      tmux send-keys -t "$pane" C-c
      sleep "$SEND_DELAY"
    fi
    printf '%s' "$text" | tmux load-buffer -b claude-worker-send -
    tmux paste-buffer -p -d -b claude-worker-send -t "$pane"
  fi
  for attempt in 1 2 3 4 5 6; do
    sleep "$SEND_DELAY"
    line="$(input_line "$name")"
    if is_paste_chip "$line" || { [[ -n "$probe" && "$line" == *"$probe"* ]]; }; then
      landed=1; break
    fi
  done
  (( landed )) || die "message never reached the input box of worker '$name' (still booting/compacting? claude-worker read $name)"
  # Let the bracketed-paste end-sequence settle before the first Enter, or the
  # TUI can absorb it into the paste and the chip never submits.
  sleep "$SEND_DELAY"
  for attempt in 1 2 3 4 5; do
    tmux send-keys -t "$pane" Enter
    sleep "$SEND_DELAY"
    line="$(input_line "$name")"
    if ! is_paste_chip "$line" && { [[ -z "$probe" || "$line" != *"$probe"* ]]; }; then
      return 0
    fi
  done
  die "message did not submit to worker '$name' after $attempt Enter attempts; the input box still holds it (claude-worker read $name to inspect)"
}

cmd_read() {
  require_name "${1:-}"
  local name="$1" lines="${2:-80}"
  [[ "$lines" =~ ^[0-9]+$ ]] || die "lines must be a number, got '$lines'"
  alive "$name" || die "worker '$name' is not running"
  tmux capture-pane -p -t "$(pane_for "$name")" -S "-$lines"
}

cmd_key() {
  # Send raw key names straight to the worker's pane (tmux send-keys names:
  # Escape, Enter, C-c, Up, …). Unlike `send`, this does NOT type text or
  # auto-submit — it's for driving TUI overlays, e.g. Escape to dismiss the
  # /usage panel the bridge opens.
  require_name "${1:-}"
  local name="$1"; shift
  alive "$name" || die "worker '$name' is not running"
  (($#)) || die "usage: claude-worker key <name> <key> [key...]"
  tmux send-keys -t "$(pane_for "$name")" "$@"
}

cmd_list() {
  local name harness printed=0
  printf '%-20s %-8s %-7s %s\n' NAME STATE ENGINE DIR
  for dir in "$STATE_ROOT"/*/; do
    [[ -d "$dir" ]] || continue
    # Skip artifact dirs without meta (e.g. created by the todo relay for
    # non-worker hash storage) — they aren't workers.
    [[ -f "$dir/meta" ]] || continue
    name="$(basename "$dir")"
    harness="$(meta_get "$name" harness)"; [[ -n "$harness" ]] || harness="claude"
    if alive "$name"; then
      printf '%-20s %-8s %-7s %s\n' "$name" running "$harness" "$(meta_get "$name" dir)"
    else
      printf '%-20s %-8s %-7s %s\n' "$name" stopped "$harness" "$(meta_get "$name" dir)"
    fi
    printed=1
  done
  # Live cw-* sessions someone created without state (e.g. by hand).
  while IFS= read -r session; do
    name="${session#"$SESSION_PREFIX"}"
    [[ -f "$STATE_ROOT/$name/meta" ]] && continue
    printf '%-20s %-8s %-7s %s\n' "$name" running "?" "(no recorded state)"
    printed=1
  done < <(tmux list-sessions -F '#S' 2>/dev/null | grep "^$SESSION_PREFIX" || true)
  (( printed )) || echo "(no workers)"
}

cmd_status() {
  require_name "${1:-}"
  local name="$1"
  if [[ -f "$STATE_ROOT/$name/meta" ]]; then
    cat "$STATE_ROOT/$name/meta"
  else
    echo "name=$name"
    echo "(no recorded state)"
  fi
  if alive "$name"; then
    echo "running: yes"
  else
    echo "running: no"
  fi
}

cmd_stop() {
  require_name "${1:-}"
  local name="$1"
  alive "$name" || die "worker '$name' is not running"
  tmux kill-session -t "=$(session_for "$name")"
  echo "stopped worker '$name' (state kept; restart with: claude-worker restart $name)"
}

cmd_restart() {
  require_name "${1:-}"
  local name="$1" dir chat harness
  dir="$(meta_get "$name" dir)"
  chat="$(meta_get "$name" chat)"
  harness="$(meta_get "$name" harness)"
  [[ -n "$harness" ]] || harness="claude"  # pre-harness workers default to claude
  [[ -n "$dir" ]] || die "no recorded state for '$name' (use: claude-worker start $name --dir DIR)"
  if alive "$name"; then
    tmux kill-session -t "=$(session_for "$name")"
  fi
  local restart_args=(--dir "$dir" --harness "$harness")
  [[ -n "$chat" ]] && restart_args+=(--chat "$chat")
  cmd_start "$name" "${restart_args[@]}"
}

cmd="${1:-}"
shift || true
case "$cmd" in
  start|send|wait|read|key|list|status|stop|restart) "cmd_$cmd" "$@" ;;
  ''|-h|--help|help) usage ;;
  *) die "unknown command '$cmd' (see claude-worker --help)" ;;
esac
