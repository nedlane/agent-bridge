#!/usr/bin/env python3
"""claude-bridge — deterministic Discord <-> Claude Code worker pipe.

Each Discord channel under the Claude category maps to one tmux-backed
interactive Claude Code worker (channel-per-repo, one worker per repo, no
threads). The bridge forwards your channel messages to the worker via
`claude-worker send`, and posts the worker's replies back when the worker's
Stop hook (claude-worker-done-relay) reports a finished turn. There is no
LLM in the bridge: Claude Code, on the Claude subscription, is the only
intelligence in the loop.

Lifecycle: workers idle longer than idle_minutes are stopped; the next
message revives them with `claude --continue`, restoring the conversation
from Claude Code's own session history.

Config:  ~/.config/claude-bridge/config.json
         {category_id, allowed_users, idle_minutes, listen_port,
          repos: {"<channel_id>": {"name": ..., "dir": ...}}}
Secrets: ~/.config/claude-workers/discord-bot-token   (Discord bot token)
         ~/.config/claude-workers/bridge-webhook      (BRIDGE_WEBHOOK_URL/
                                                       BRIDGE_WEBHOOK_SECRET,
                                                       shared with the hooks)

Commands are native Discord slash commands (allowed users; synced per guild
on connect). The `worker` option defaults to the channel's mapped worker:
  /status                  list all workers and their state
  /stop /restart /screen [worker]
  /model <model> [worker]  switch the worker's model
  /clear [worker]          fresh context now: restart without --continue
  /fresh [worker]          shut down + fresh next start (no resume, lazy)
  /compact [focus] [worker] compact the worker's context
  /checkin [worker]        ask a running worker for a progress update
  /addrepo <name> <path>   create #<name> under the category + map it
A plain message starting with "/" that is NOT one of the above is typed into
the worker as keystrokes, so any other Claude Code slash command still works.
The worker named "orchestrator" additionally gets the ORCHESTRATOR brief, so
its channel doubles as a natural-language remote for all of the above.

Only stdlib is imported at module level so the pure helpers stay testable
without discord.py installed (tests/claude-bridge-smoke.sh).
"""

import argparse
import asyncio
import hashlib
import hmac
import json
import os
import subprocess
import time

CONFIG_PATH = os.path.expanduser(
    os.environ.get("CLAUDE_BRIDGE_CONFIG", "~/.config/claude-bridge/config.json")
)
TOKEN_FILE = os.path.expanduser(
    os.environ.get(
        "CLAUDE_BRIDGE_TOKEN_FILE", "~/.config/claude-workers/discord-bot-token"
    )
)
SECRET_FILE = os.path.expanduser(
    os.environ.get(
        "CLAUDE_WORKERS_BRIDGE_WEBHOOK_FILE", "~/.config/claude-workers/bridge-webhook"
    )
)
STATE_ROOT = os.path.expanduser(
    os.environ.get("CLAUDE_WORKERS_STATE", "~/.local/state/claude-workers")
)

# React with this on any message in a worker channel to have the bridge post
# that worker's live TUI screen — an eyes-on peek with no command to type.
PEEK_EMOJI = "👀"

DISCORD_LIMIT = 2000
REPLY_CAP = 8000

# Injected into every worker's system prompt: the worker itself is the
# publisher. It messages Ned through discord-notify (which auto-targets the
# worker's repo channel, and can attach images/files with -i); the bridge's
# transcript extraction is only a fallback for turns where the worker said
# nothing. This is what makes multi-hour tasks safe: no screen scraping, no
# per-turn chatter.
PROTOCOL = """You are running as a Discord-bridged Claude Code worker for Ned.
Your terminal output is NOT reliably visible to him. The ONLY reliable way to
message him is the discord-notify CLI, which posts to this conversation's
Discord channel automatically:
  discord-notify "short message"        # or pipe a longer body: ... | discord-notify -
  discord-notify -i screenshot.png "caption"   # attach an image/file (repeatable)
Do NOT run `discord-notify --help` just to inspect it (it prints usage and
sends nothing, but the syntax you need is right here). Files Ned attaches in
Discord arrive to you as local file paths to read off disk.
Message him ONLY when one of these happens:
  1. The task is complete - send a concise result summary.
  2. You are blocked on a question or decision only Ned can answer - ask it,
     then stop and wait; his answer arrives as your next user message.
  3. He explicitly asks for a check-in - send 3-5 lines of progress, then
     continue working.
Otherwise work silently. No progress spam. Long tasks (multiple hours) are
expected - do not stop early to report, do not ask for permission to
continue.
You can also operate the bridge with tools (never by reading screens or
internals): `bridge-ctl addrepo <name> </abs/path>` creates a new repo
channel/conversation and maps it; `bridge-ctl repos` lists mappings;
`discord-notify -t discord:<channel_id> "..."` messages a specific channel.
Your discord-notify and claude-bridge skills document the rest."""

# The worker named "orchestrator" is Ned's natural-language remote for the
# whole control plane: it gets this brief on top of PROTOCOL so "spin up a
# worker on ghpr and have it triage the failing tests" becomes tool calls
# instead of Ned typing bot commands. The `/` slash commands work everywhere.
ORCHESTRATOR = """Additionally, you are Ned's ORCHESTRATOR session. He will ask
you in natural language to run this machine's Claude-worker control plane;
translate his requests into these tools instead of telling him which bot
commands to type:
  bridge-ctl repos                        existing repo channels/workers
  bridge-ctl addrepo <name> </abs/path>   new repo channel (returns channel_id)
  bridge-ctl start <name>                 start that repo's worker (it gets
                                          this same Discord protocol)
  claude-worker list / status <name> / read <name> [lines]
  claude-worker send <name> "msg"         instruct a running worker
                                          (--type for /slash commands)
  claude-worker stop <name> / restart <name>
  discord-notify -t discord:<channel_id> "..."   post into any repo channel
  agent-checkup                           control-plane health report
  systemctl --user status claude-bridge / journalctl --user -u claude-bridge -n 50
Hand real repo work to that repo's worker (bridge-ctl start, then
claude-worker send) — do not do another repo's task yourself in this session.
Orchestration requests are usually quick: do them, then confirm what you did
via discord-notify."""

# Prefixed onto every chat message relayed from Discord into a worker. Over a
# long session a worker drifts back to plain terminal replies (which Ned never
# sees); stamping each inbound turn keeps "answer on Discord" in front of it.
DISCORD_TAG = (
    "[Discord message from Ned — reply with `discord-notify` so he sees it; "
    "your terminal output is not visible to him.]"
)


def system_prompt(name):
    """The injected protocol; the orchestrator also gets the control-plane brief."""
    if name == "orchestrator":
        return PROTOCOL + "\n\n" + ORCHESTRATOR
    return PROTOCOL


def start_args(name, directory, channel_id, resume):
    """argv for claude-worker start, with the Discord protocol injected."""
    args = [
        "claude-worker", "start", name,
        "--dir", directory,
        "--chat", f"discord:{channel_id}",
        "--",
    ]
    if resume:
        args.append("--continue")
    args += ["--append-system-prompt", system_prompt(name)]
    return args

# --------------------------------------------------------------------------
# Pure helpers (no I/O beyond explicit paths; covered by the smoke test)
# --------------------------------------------------------------------------


def default_config():
    return {
        "category_id": 0,
        "allowed_users": [],
        "idle_minutes": 45,
        "listen_port": 8765,
        "repos": {},
    }


def load_config(path=None):
    path = path or CONFIG_PATH
    cfg = default_config()
    try:
        with open(path) as f:
            cfg.update(json.load(f))
    except FileNotFoundError:
        pass
    return cfg


def save_config(cfg, path=None):
    path = path or CONFIG_PATH
    os.makedirs(os.path.dirname(path), exist_ok=True)
    tmp = path + ".tmp"
    with open(tmp, "w") as f:
        json.dump(cfg, f, indent=2)
        f.write("\n")
    os.replace(tmp, path)


def split_message(text, limit=DISCORD_LIMIT):
    """Split on line boundaries under Discord's message size limit."""
    if len(text) > REPLY_CAP:
        text = text[:REPLY_CAP] + "\n… (truncated — use /screen for the live view)"
    chunks, current = [], ""
    for line in text.splitlines(keepends=True):
        while len(line) > limit:  # single pathological line
            chunks.append(line[:limit])
            line = line[limit:]
        if len(current) + len(line) > limit:
            chunks.append(current)
            current = line
        else:
            current += line
    if current.strip():
        chunks.append(current)
    return [c.rstrip("\n") for c in chunks if c.strip()]


def extract_last_reply(transcript_path):
    """Last assistant text from a Claude Code session transcript (jsonl)."""
    reply = ""
    try:
        with open(transcript_path) as f:
            for line in f:
                try:
                    entry = json.loads(line)
                except ValueError:
                    continue
                if entry.get("type") != "assistant":
                    continue
                blocks = (entry.get("message") or {}).get("content") or []
                texts = [
                    b.get("text", "")
                    for b in blocks
                    if isinstance(b, dict) and b.get("type") == "text"
                ]
                if any(t.strip() for t in texts):
                    reply = "\n".join(t for t in texts if t.strip())
    except OSError:
        return ""
    return reply.strip()


def extract_new_reply(transcript_path, offset=0):
    """Last assistant text appended after byte `offset`.

    Returns (reply, new_offset). Only complete lines are consumed, so a
    mid-write trailing line is left for the next attempt. This is what makes
    reply delivery immune to the Stop-hook/transcript-flush race: each turn
    event only ever reads content written since the previous turn, so a
    stale read returns "" (retry) instead of the previous turn's reply.
    """
    try:
        with open(transcript_path, "rb") as f:
            f.seek(offset)
            buf = f.read()
    except OSError:
        return "", offset
    end = buf.rfind(b"\n")
    if end < 0:
        return "", offset
    reply = ""
    for line in buf[: end + 1].splitlines():
        try:
            entry = json.loads(line)
        except ValueError:
            continue
        if entry.get("type") != "assistant":
            continue
        blocks = (entry.get("message") or {}).get("content") or []
        texts = [
            b.get("text", "")
            for b in blocks
            if isinstance(b, dict) and b.get("type") == "text"
        ]
        if any(t.strip() for t in texts):
            reply = "\n".join(t for t in texts if t.strip())
    return reply.strip(), offset + end + 1


def verify_signature(body, header, secret):
    if not header or not secret:
        return False
    expected = hmac.new(secret.encode(), body, hashlib.sha256).hexdigest()
    return hmac.compare_digest(header, expected)


def read_kv_file(path):
    kv = {}
    try:
        with open(path) as f:
            for line in f:
                if "=" in line and not line.lstrip().startswith("#"):
                    k, _, v = line.partition("=")
                    kv[k.strip()] = v.strip()
    except OSError:
        pass
    return kv


def channel_from_chat(chat):
    """'discord:123' or 'discord:123:456' -> 123 (int) or None."""
    parts = (chat or "").split(":")
    if len(parts) >= 2 and parts[0] == "discord" and parts[1].isdigit():
        return int(parts[1])
    return None


def tag_inbound(text, typed=False):
    """Stamp a relayed Discord message so the worker keeps replying on Discord.

    Slash commands (typed) and empty bodies pass through untouched — a command
    must reach the TUI verbatim, and there's nothing to remind about an empty
    turn.
    """
    if typed or not (text or "").strip():
        return text
    return f"{DISCORD_TAG}\n\n{text}"


def compose_inbound(text, attachment_paths=None, reply_quote=None):
    """Assemble what actually gets delivered to the worker's TUI.

    A quoted snippet of the message being replied to (if any) goes first, then
    the message text, then a footer listing any downloaded attachment paths so
    Claude can open them off disk. Any part may be empty.
    """
    parts = []
    if reply_quote:
        parts.append(f"(replying to: {reply_quote})")
    if text:
        parts.append(text)
    paths = list(attachment_paths or [])
    if paths:
        listed = "\n".join(f"  - {p}" for p in paths)
        noun = "file" if len(paths) == 1 else "files"
        parts.append(
            f"[Ned attached {len(paths)} {noun} — read {'it' if len(paths) == 1 else 'them'} "
            f"from disk:\n{listed}]"
        )
    return "\n\n".join(parts)


def compose_edit(content):
    """Frame an edited Discord message as a steering note for a live worker."""
    return f"[Ned edited his previous message — it now reads:]\n\n{content}"


def reply_preview(body, limit=200):
    """One-line, length-capped snippet of a replied-to message (or None)."""
    body = (body or "").strip().replace("\n", " ")
    if not body:
        return None
    return body[:limit] + ("…" if len(body) > limit else "")


# --------------------------------------------------------------------------
# claude-worker subprocess wrappers (sync; called via asyncio.to_thread)
# --------------------------------------------------------------------------


def _run(args, timeout=180, input_text=None):
    try:
        return subprocess.run(
            args, capture_output=True, text=True, timeout=timeout, check=False,
            input=input_text,
        )
    except (FileNotFoundError, subprocess.TimeoutExpired) as exc:
        # Surface "claude-worker not on PATH" and hangs as a failed result so
        # callers report them to the channel instead of dying in on_message.
        return subprocess.CompletedProcess(args, 127, stdout="", stderr=str(exc))


def worker_alive(name):
    r = _run(["claude-worker", "status", name], timeout=15)
    return "running: yes" in r.stdout


def worker_busy(name):
    r = _run(["claude-worker", "read", name, "30"], timeout=15)
    return "esc to interrupt" in r.stdout


def screen_is_ready(screen):
    """True when a worker pane shows an idle, input-ready prompt.

    The readiness counterpart to worker_busy, used to gate cold-start
    delivery: false during boot, while a turn runs ("esc to interrupt"),
    while a --continue resume auto-compacts ("Compacting"), at the folder-trust
    dialog, or at the resume-mode dialog (whose menu cursor is also a "❯") — so
    the bridge never pastes the waking message into a TUI that is still loading
    or showing a blocking dialog and would silently discard it.
    """
    if "❯" not in screen:
        return False
    blockers = (
        "esc to interrupt", "Compacting", "Do you trust", "trust this folder",
        "Resume from summary", "Resume full session",
    )
    return not any(b in screen for b in blockers)


def worker_screen(name, lines=40):
    r = _run(["claude-worker", "read", name, str(lines)], timeout=15)
    return r.stdout if r.returncode == 0 else r.stderr


def render_screen_png(text, path):
    """Render a captured screen to a PNG via term-shot. True on success — a
    wide TUI capture is unreadable as a mobile code block, legible as an image.
    """
    r = _run(["term-shot", path], timeout=20, input_text=text)
    return r.returncode == 0 and os.path.isfile(path)


def worker_start(name, directory, channel_id, resume):
    return _run(start_args(name, directory, channel_id, resume), timeout=180)


def worker_send(name, text, typed=False):
    args = ["claude-worker", "send", name]
    if typed:
        args.append("--type")
    return _run(args + [text], timeout=30)


def worker_stop(name):
    return _run(["claude-worker", "stop", name], timeout=30)


def worker_has_state(name, state_root=None):
    state_root = state_root or os.path.expanduser("~/.local/state/claude-workers")
    return os.path.isfile(os.path.join(state_root, name, "meta"))


def fresh_marker_path(name, state_root=None):
    return os.path.join(state_root or STATE_ROOT, name, "no-resume")


def fresh_pending(name, state_root=None):
    """True when /fresh was armed: the worker was shut down and its next
    start must begin a brand-new session instead of --continue-resuming the
    old conversation."""
    return os.path.isfile(fresh_marker_path(name, state_root))


def arm_fresh(name, state_root=None):
    """Mark the worker so its next start skips --continue. The marker is a file
    beside the worker's state (which `claude-worker stop` keeps), so the lazy
    revive on the next message reads it and starts clean."""
    path = fresh_marker_path(name, state_root)
    os.makedirs(os.path.dirname(path), exist_ok=True)
    open(path, "w").close()


def disarm_fresh(name, state_root=None):
    """Consume the fresh marker — called once the worker has (re)started, so a
    one-shot /fresh doesn't wipe every subsequent revive."""
    try:
        os.remove(fresh_marker_path(name, state_root))
    except FileNotFoundError:
        pass


def should_resume(has_state, fresh):
    """Resume the prior conversation only with saved state and no armed fresh
    start."""
    return has_state and not fresh


# --------------------------------------------------------------------------
# Runtime (discord.py + aiohttp imported here so tests don't need them)
# --------------------------------------------------------------------------


def run_bridge(config_path):  # pragma: no cover - exercised live, not in tests
    import logging

    import discord
    from aiohttp import web

    # Without this, exceptions inside discord.py event handlers vanish.
    logging.basicConfig(level=logging.INFO, format="%(name)s: %(message)s")

    cfg = load_config(config_path)
    secret = read_kv_file(SECRET_FILE).get("BRIDGE_WEBHOOK_SECRET", "")
    with open(TOKEN_FILE) as f:
        token = f.read().strip()

    intents = discord.Intents.default()
    intents.message_content = True
    intents.reactions = True
    client = discord.Client(intents=intents)

    last_activity = {}  # worker name -> epoch seconds
    offsets = {}        # transcript path -> bytes already consumed
    notified = set()    # workers that messaged Ned themselves this turn

    async def settle_file(path, timeout=10):
        """Wait until `path` stops changing (two identical mtimes 0.5s apart)."""
        last = -1
        for _ in range(int(timeout * 2)):
            try:
                now = os.stat(path).st_mtime_ns
            except OSError:
                now = -1
            if now == last and now != -1:
                return
            last = now
            await asyncio.sleep(0.5)

    async def wait_ready(name, timeout=180):
        """Poll until the worker pane is idle and input-ready (or timeout).

        claude-worker start returns success even when its own readiness check
        timed out, and a --continue resume can kick off auto-compaction that
        wasn't visible yet when that check passed. Requiring the ready state on
        two consecutive polls keeps the brief idle window between resume and
        compaction from being mistaken for readiness. Returns True if ready,
        False on timeout or if the worker died.
        """
        stable = 0
        deadline = time.time() + timeout
        while time.time() < deadline:
            if not await asyncio.to_thread(worker_alive, name):
                return False
            screen = await asyncio.to_thread(worker_screen, name, 40)
            if screen_is_ready(screen):
                stable += 1
                if stable >= 2:
                    return True
            else:
                stable = 0
            await asyncio.sleep(2)
        return False

    def repo_for_channel(channel_id):
        return cfg["repos"].get(str(channel_id))

    def channel_for_worker(name):
        for cid, repo in cfg["repos"].items():
            if repo["name"] == name:
                return int(cid)
        return None

    async def post(channel_id, text, attachments=None):
        channel = client.get_channel(channel_id)
        if channel is None:
            print(f"[bridge] unknown channel {channel_id}, dropping message")
            return
        files = []
        for path in attachments or []:
            if isinstance(path, str) and os.path.isfile(path):
                files.append(discord.File(path))
            else:
                print(f"[bridge] attachment not found, skipping: {path!r}")
        chunks = split_message(text) if text else []
        # Send the files alongside the final text chunk so an image and its
        # caption arrive together; if there's no text, post the files alone. A
        # rejected upload (too large, gone) must not crash the event handler.
        try:
            if not chunks and files:
                await channel.send(files=files)
                return
            for i, chunk in enumerate(chunks):
                if files and i == len(chunks) - 1:
                    await channel.send(chunk, files=files)
                else:
                    await channel.send(chunk)
        except discord.HTTPException as e:
            print(f"[bridge] channel {channel_id} send failed: {e}")
            if files:
                # Salvage the text so the caption isn't lost with the upload.
                for chunk in chunks:
                    try:
                        await channel.send(chunk)
                    except discord.HTTPException:
                        pass

    async def render_peek(name):
        """Build a worker's live-screen payload as (text, attachments): an
        image (falls back to a code block if rendering is unavailable). Shared
        by the 👀 reaction and the /screen command."""
        if not await asyncio.to_thread(worker_alive, name):
            return f"👀 `{name}` isn't running right now.", None
        screen = await asyncio.to_thread(worker_screen, name, 40)
        png = os.path.join(STATE_ROOT, name, "peek.png")
        if await asyncio.to_thread(render_screen_png, screen, png):
            return f"👀 `{name}` — live screen", [png]
        return f"👀 `{name}` live screen:\n```\n{screen}\n```", None

    async def peek_screen(channel_id, name):
        """Post a worker's live screen to a channel — used by the 👀 reaction."""
        text, attachments = await render_peek(name)
        await post(channel_id, text, attachments)

    async def deliver(name, text, message=None, typed=False):
        # Messages go straight in even mid-turn — Claude Code natively queues
        # typed-while-running input as steering, which is what check-ins and
        # course corrections need. ⏳ just signals "delivered while working".
        last_activity[name] = time.time()
        busy = await asyncio.to_thread(worker_busy, name)
        text = tag_inbound(text, typed)
        r = await asyncio.to_thread(worker_send, name, text, typed)
        if r.returncode != 0:
            # A send that lands exactly on a turn boundary can wedge in the
            # TUI's queued-message state (displayed but never submitted, even
            # with Enter retries). Recover deterministically: restart the
            # worker with --continue and re-send once.
            repo = next(
                (x for x in cfg["repos"].values() if x["name"] == name), None
            )
            channel_id = channel_for_worker(name)
            if repo and channel_id:
                print(f"[bridge] {name}: send wedged, restarting worker to recover")
                await asyncio.to_thread(worker_stop, name)
                r2 = await asyncio.to_thread(
                    worker_start, name, repo["dir"], channel_id, True
                )
                if r2.returncode == 0:
                    # The restart resumes with --continue and may auto-compact;
                    # wait for an input-ready prompt before re-sending so the
                    # recovery doesn't re-lose the message into a loading TUI.
                    await wait_ready(name)
                    r = await asyncio.to_thread(worker_send, name, text, typed)
        if r.returncode != 0:
            if message:
                await message.channel.send(f"⚠️ send failed: {r.stderr.strip()}")
            return
        if message:
            await message.add_reaction("⏳" if busy else "✅")

    async def save_attachments(name, message):
        """Download a message's Discord attachments into the worker's inbox
        dir and return their local paths, so Claude can Read them off disk."""
        if not message.attachments:
            return []
        inbox = os.path.join(STATE_ROOT, name, "inbox")
        try:
            os.makedirs(inbox, exist_ok=True)
        except OSError as e:
            print(f"[bridge] {name}: cannot create inbox {inbox}: {e}")
            return []
        paths = []
        for att in message.attachments:
            safe = os.path.basename(att.filename or "").strip() or "file"
            dest = os.path.join(inbox, f"{message.id}-{safe}")
            try:
                await att.save(dest)
                paths.append(dest)
            except (discord.HTTPException, OSError) as e:
                print(f"[bridge] {name}: failed to save {att.filename!r}: {e}")
        return paths

    async def reply_snippet(message):
        """A short quote of the message this one is replying to, or None."""
        ref = message.reference
        if ref is None:
            return None
        src = ref.resolved
        if src is None and ref.message_id:
            try:
                src = await message.channel.fetch_message(ref.message_id)
            except discord.HTTPException:
                return None
        return reply_preview(getattr(src, "content", "") if src else "")

    async def handle_repo_message(message, repo):
        name, directory = repo["name"], repo["dir"]
        if not await asyncio.to_thread(worker_alive, name):
            resume = should_resume(worker_has_state(name), fresh_pending(name))
            await message.add_reaction("🚀" if resume else "🧼")
            r = await asyncio.to_thread(
                worker_start, name, directory, message.channel.id, resume
            )
            if r.returncode != 0:
                await message.channel.send(
                    f"⚠️ could not start worker `{name}`: {r.stderr.strip()}"
                )
                return
            # Started — consume any armed /fresh so it only skips resume once.
            await asyncio.to_thread(disarm_fresh, name)
            # The resume can auto-compact; wait for a genuinely input-ready
            # prompt before pasting, or this waking message is discarded when
            # the resume/compaction redraw replaces the input box.
            if not await wait_ready(name):
                await message.channel.send(
                    f"⚠️ `{name}` resumed but isn't input-ready yet (still "
                    "compacting?). Re-send your message in a moment."
                )
                return
        # Leading "/" means a Claude Code slash command — type it so the TUI
        # actually executes it instead of treating it as pasted text. Commands
        # go verbatim; everything else can carry a reply quote and attachments.
        if message.content.startswith("/"):
            await deliver(name, message.content, message, typed=True)
            return
        paths = await save_attachments(name, message)
        quote = await reply_snippet(message)
        composed = compose_inbound(message.content, paths, quote)
        await deliver(name, composed, message, typed=False)

    def repo_by_name(name):
        return next((x for x in cfg["repos"].values() if x["name"] == name), None)

    # --- command actions (shared by the slash commands below) ---------------
    # Each returns (text, attachments) so the caller can respond however it
    # likes; worker restarts block, so their callers defer the interaction.
    async def do_status():
        r = await asyncio.to_thread(_run, ["claude-worker", "list"], 15)
        return f"```\n{r.stdout}\n```", None

    async def do_fresh(name):
        # Shut down now and arm a fresh start: the next message begins a
        # brand-new session with no --continue, without resuming first. The
        # marker survives the stop.
        await asyncio.to_thread(worker_stop, name)
        await asyncio.to_thread(arm_fresh, name)
        return (
            f"🧼 `{name}` shut down — your next message starts a fresh "
            "context (no resume).", None,
        )

    async def do_stop(name):
        await asyncio.to_thread(worker_stop, name)
        return f"🛑 stopped `{name}`", None

    async def do_restart(name):
        repo = repo_by_name(name)
        if not repo:
            return f"⚠️ no repo channel mapped for `{name}`", None
        await asyncio.to_thread(worker_stop, name)
        r = await asyncio.to_thread(
            worker_start, name, repo["dir"], channel_for_worker(name), True
        )
        # Explicit resume: cancel any armed fresh so it can't re-fire.
        await asyncio.to_thread(disarm_fresh, name)
        return (
            f"🔄 restarted `{name}`" if r.returncode == 0
            else f"⚠️ restart failed: {r.stderr.strip()}", None,
        )

    async def do_clear(name):
        # Deterministic context wipe: a fresh session (no --continue) instead
        # of the /clear TUI command, so it works regardless of worker state
        # and re-injects the Discord protocol.
        repo = repo_by_name(name)
        if not repo:
            return f"⚠️ no repo channel mapped for `{name}`", None
        await asyncio.to_thread(worker_stop, name)
        r = await asyncio.to_thread(
            worker_start, name, repo["dir"], channel_for_worker(name), False
        )
        await asyncio.to_thread(disarm_fresh, name)
        return (
            f"🧹 `{name}` restarted with a fresh context" if r.returncode == 0
            else f"⚠️ clear failed: {r.stderr.strip()}", None,
        )

    # --- native Discord slash commands --------------------------------------
    # Registered as application commands (synced per-guild in on_ready), so
    # they arrive as interactions — no "!" prefix, and no collision with the
    # "type any /message into the worker" passthrough for Claude Code commands.
    tree = discord.app_commands.CommandTree(client)
    describe = discord.app_commands.describe

    async def guard(interaction, worker):
        """Authorize + resolve the target worker. Returns the worker name, or
        None after having already replied with an error."""
        if interaction.user.id not in cfg["allowed_users"]:
            await interaction.response.send_message("⛔ not authorized", ephemeral=True)
            return None
        name = worker or (
            repo["name"] if (repo := repo_for_channel(interaction.channel_id)) else None
        )
        if not name:
            await interaction.response.send_message(
                "⚠️ no worker mapped to this channel — pass `worker`", ephemeral=True
            )
            return None
        return name

    async def reply(interaction, text, attachments=None):
        files = [
            discord.File(a) for a in (attachments or []) if os.path.isfile(a)
        ]
        await interaction.followup.send(text, files=files)

    @tree.command(name="status", description="List all workers and their state")
    async def slash_status(interaction):
        if interaction.user.id not in cfg["allowed_users"]:
            await interaction.response.send_message("⛔ not authorized", ephemeral=True)
            return
        await interaction.response.defer(thinking=True)
        await reply(interaction, *await do_status())

    @tree.command(name="fresh", description="Shut a worker down; next message starts a fresh session (no resume)")
    @describe(worker="Worker name (defaults to this channel's worker)")
    async def slash_fresh(interaction, worker: str = None):
        if not (name := await guard(interaction, worker)):
            return
        await interaction.response.defer(thinking=True)
        await reply(interaction, *await do_fresh(name))

    @tree.command(name="clear", description="Fresh context now: restart the worker without --continue")
    @describe(worker="Worker name (defaults to this channel's worker)")
    async def slash_clear(interaction, worker: str = None):
        if not (name := await guard(interaction, worker)):
            return
        await interaction.response.defer(thinking=True)
        await reply(interaction, *await do_clear(name))

    @tree.command(name="stop", description="Stop a worker (state kept; a message revives it)")
    @describe(worker="Worker name (defaults to this channel's worker)")
    async def slash_stop(interaction, worker: str = None):
        if not (name := await guard(interaction, worker)):
            return
        await interaction.response.defer(thinking=True)
        await reply(interaction, *await do_stop(name))

    @tree.command(name="restart", description="Restart a worker, resuming its conversation")
    @describe(worker="Worker name (defaults to this channel's worker)")
    async def slash_restart(interaction, worker: str = None):
        if not (name := await guard(interaction, worker)):
            return
        await interaction.response.defer(thinking=True)
        await reply(interaction, *await do_restart(name))

    @tree.command(name="screen", description="Peek at a worker's live screen")
    @describe(worker="Worker name (defaults to this channel's worker)")
    async def slash_screen(interaction, worker: str = None):
        if not (name := await guard(interaction, worker)):
            return
        await interaction.response.defer(thinking=True)
        await reply(interaction, *await render_peek(name))

    @tree.command(name="checkin", description="Ask a running worker for a progress update")
    @describe(worker="Worker name (defaults to this channel's worker)")
    async def slash_checkin(interaction, worker: str = None):
        if not (name := await guard(interaction, worker)):
            return
        await interaction.response.defer(thinking=True)
        await deliver(
            name,
            "Ned is asking for a check-in right now: send him 3-5 lines of "
            "progress (current step, what's left, any blockers) via "
            "discord-notify, then continue the task.",
        )
        await interaction.followup.send(f"📨 asked `{name}` for a check-in")

    @tree.command(name="model", description="Switch a worker's model")
    @describe(model="e.g. opus, sonnet, haiku", worker="Worker (defaults to this channel's worker)")
    async def slash_model(interaction, model: str, worker: str = None):
        if not (name := await guard(interaction, worker)):
            return
        await interaction.response.defer(thinking=True)
        await deliver(name, f"/model {model}", typed=True)
        await interaction.followup.send(f"🔧 sent `/model {model}` to `{name}`")

    @tree.command(name="compact", description="Compact a worker's context")
    @describe(focus="Optional focus for the compaction", worker="Worker (defaults to this channel's worker)")
    async def slash_compact(interaction, focus: str = None, worker: str = None):
        if not (name := await guard(interaction, worker)):
            return
        await interaction.response.defer(thinking=True)
        await deliver(name, "/compact" + (f" {focus}" if focus else ""), typed=True)
        await interaction.followup.send(f"🗜️ compacting `{name}`")

    @tree.command(name="addrepo", description="Create a Discord channel and map a repo to a worker")
    @describe(name="Worker/channel name", path="Absolute path to the repo")
    async def slash_addrepo(interaction, name: str, path: str):
        if interaction.user.id not in cfg["allowed_users"]:
            await interaction.response.send_message("⛔ not authorized", ephemeral=True)
            return
        directory = os.path.expanduser(path)
        if not os.path.isdir(directory):
            await interaction.response.send_message(
                f"⚠️ no such directory: {directory}", ephemeral=True
            )
            return
        await interaction.response.defer(thinking=True)
        category = client.get_channel(int(cfg["category_id"]))
        channel = await interaction.guild.create_text_channel(name, category=category)
        cfg["repos"][str(channel.id)] = {"name": name, "dir": directory}
        save_config(cfg, config_path)
        await interaction.followup.send(
            f"✅ created {channel.mention} → `{directory}` (worker `{name}`)"
        )

    @client.event
    async def on_ready():
        # Copy the globally-defined commands into each guild and sync there:
        # guild syncs are instant, so the slash menu is usable right away.
        synced = 0
        for guild in client.guilds:
            try:
                tree.copy_global_to(guild=guild)
                synced = len(await tree.sync(guild=guild))
            except discord.HTTPException as e:
                print(f"[bridge] slash sync failed for {guild.name} "
                      f"(bot missing the applications.commands scope?): {e}")
        print(f"[bridge] connected to Discord as {client.user} "
              f"({len(cfg['repos'])} repo channel(s) mapped, {synced} slash command(s))")

    @client.event
    async def on_message(message):
        # Control verbs are native slash commands (interactions, handled by the
        # command tree) — plain messages are always worker input.
        if message.author.bot or message.author.id not in cfg["allowed_users"]:
            return
        repo = repo_for_channel(message.channel.id)
        if repo:
            await handle_repo_message(message, repo)

    @client.event
    async def on_message_edit(before, after):
        # Relay an edit as a steering note so a live worker sees the correction
        # instead of acting on stale text. Ignore no-op edits (Discord fires
        # this when it attaches a link embed) and edits to a stopped worker —
        # the next fresh message resumes that conversation anyway.
        if after.author.bot or after.author.id not in cfg["allowed_users"]:
            return
        if before.content == after.content or not after.content.strip():
            return
        if after.content.startswith("/"):
            return
        repo = repo_for_channel(after.channel.id)
        if not repo:
            return
        name = repo["name"]
        if not await asyncio.to_thread(worker_alive, name):
            return
        await deliver(name, compose_edit(after.content), after, typed=False)

    @client.event
    async def on_raw_reaction_add(payload):
        # React with 👀 on any message in a worker channel to peek at that
        # worker's live screen — observability with no command to type.
        if payload.user_id not in cfg["allowed_users"]:
            return
        if payload.member and payload.member.bot:
            return
        if str(payload.emoji) != PEEK_EMOJI:
            return
        repo = repo_for_channel(payload.channel_id)
        if not repo:
            return
        await peek_screen(payload.channel_id, repo["name"])

    # ---- localhost event listener (Stop hook + relays post here) ----------
    async def handle_event(request):
        body = await request.read()
        if not verify_signature(
            body, request.headers.get("X-Webhook-Signature", ""), secret
        ):
            return web.json_response({"error": "bad signature"}, status=401)
        try:
            event = json.loads(body)
        except ValueError:
            return web.json_response({"error": "bad json"}, status=400)

        etype = event.get("event_type", "")
        if etype == "claude.worker.turn_ended":
            name = event.get("worker", "")
            channel_id = channel_from_chat(event.get("chat", "")) or channel_for_worker(name)
            path = event.get("transcript_path", "")
            last_activity[name] = time.time()
            # Push-first: if the worker already messaged Ned this turn via
            # discord-notify, the fallback stays silent — but the transcript
            # offset is still consumed so a later fallback can't replay this
            # turn's text.
            worker_spoke = name in notified
            notified.discard(name)
            if channel_id and worker_spoke:
                _, off = extract_new_reply(path, offsets.get(path, 0))
                offsets[path] = off
                print(f"[bridge] {name}: turn ended, worker already notified — fallback silent")
            elif channel_id:
                # The Stop hook can fire before Claude Code flushes the final
                # assistant message, and a stale read returns the PREVIOUS
                # turn's reply (the one-prompt-behind bug). Known transcripts
                # are read incrementally from a byte offset so only this
                # turn's text counts; unseen transcripts (fresh worker or
                # bridge restart) are read whole after the file settles.
                reply = ""
                if path in offsets:
                    off = offsets[path]
                    for _ in range(10):
                        reply, off = extract_new_reply(path, off)
                        if reply:
                            break
                        await asyncio.sleep(1)
                    offsets[path] = off
                elif path:
                    await settle_file(path)
                    reply = extract_last_reply(path)
                    try:
                        offsets[path] = os.path.getsize(path)
                    except OSError:
                        pass
                print(f"[bridge] {name}: turn ended, posting "
                      f"{len(reply) if reply else 0} chars to {channel_id}")
                if not reply:
                    reply = "(no new reply text captured — use /screen)"
                await post(channel_id, reply)
        elif etype == "claude.bridge.addrepo":
            repo_name = (event.get("name") or "").strip()
            repo_path = os.path.expanduser(event.get("path") or "")
            if not repo_name or not os.path.isdir(repo_path):
                return web.json_response(
                    {"error": f"invalid name or directory: {repo_name!r} {repo_path!r}"},
                    status=400,
                )
            category = client.get_channel(int(cfg["category_id"]))
            if category is None:
                return web.json_response({"error": "Claude category not found"}, status=400)
            channel = await category.guild.create_text_channel(
                repo_name, category=category
            )
            cfg["repos"][str(channel.id)] = {"name": repo_name, "dir": repo_path}
            save_config(cfg, config_path)
            print(f"[bridge] addrepo: #{channel.name} ({channel.id}) -> {repo_path}")
            return web.json_response(
                {"status": "ok", "channel_id": str(channel.id), "channel": channel.name}
            )
        elif etype == "claude.bridge.start":
            # Tools-based worker start (bridge-ctl start) — same path as a
            # channel message, so the worker gets the injected protocol and
            # --continue resume, unlike a bare `claude-worker start`.
            name = (event.get("name") or "").strip()
            repo = next(
                (r for r in cfg["repos"].values() if r["name"] == name), None
            )
            channel_id = channel_for_worker(name)
            if not repo or not channel_id:
                return web.json_response(
                    {"error": f"no repo channel mapped for worker {name!r}"},
                    status=400,
                )
            if await asyncio.to_thread(worker_alive, name):
                last_activity[name] = time.time()
                return web.json_response({"status": "ok", "note": "already running"})
            resume = should_resume(worker_has_state(name), fresh_pending(name))
            r = await asyncio.to_thread(
                worker_start, name, repo["dir"], channel_id, resume
            )
            if r.returncode != 0:
                return web.json_response({"error": r.stderr.strip()[-400:]}, status=500)
            await asyncio.to_thread(disarm_fresh, name)
            last_activity[name] = time.time()
            print(f"[bridge] start event: worker {name} running")
        elif etype == "claude.worker.send":
            worker = event.get("worker", "")
            if worker:
                notified.add(worker)
            channel_id = channel_from_chat(event.get("chat", ""))
            attachments = event.get("attachments") or []
            if channel_id and (event.get("content") or attachments):
                await post(channel_id, event.get("content") or "", attachments)
        return web.json_response({"status": "ok"})

    async def reaper():
        while True:
            await asyncio.sleep(60)
            idle_s = cfg["idle_minutes"] * 60
            for repo in list(cfg["repos"].values()):
                name = repo["name"]
                last = last_activity.get(name)
                if last is None or time.time() - last < idle_s:
                    continue
                if await asyncio.to_thread(worker_alive, name) and not (
                    await asyncio.to_thread(worker_busy, name)
                ):
                    await asyncio.to_thread(worker_stop, name)
                    last_activity.pop(name, None)
                    channel_id = channel_for_worker(name)
                    if channel_id:
                        await post(
                            channel_id,
                            f"💤 `{name}` idle for {cfg['idle_minutes']}m — stopped. "
                            "Your next message resumes the conversation.",
                        )

    async def main():
        app = web.Application()
        app.router.add_post("/event", handle_event)
        runner = web.AppRunner(app)
        await runner.setup()
        site = web.TCPSite(runner, "127.0.0.1", int(cfg["listen_port"]))
        await site.start()
        print(f"[bridge] event listener on 127.0.0.1:{cfg['listen_port']}")
        asyncio.create_task(reaper())
        await client.start(token)

    asyncio.run(main())


if __name__ == "__main__":
    parser = argparse.ArgumentParser(description=__doc__.splitlines()[0])
    parser.add_argument("--config", default=CONFIG_PATH)
    args = parser.parse_args()
    run_bridge(args.config)
