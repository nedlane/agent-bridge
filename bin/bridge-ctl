#!/usr/bin/env bash
# Operate the claude-bridge from any shell or Claude session — the
# tools-based interface workers use instead of reading screens or config
# internals. Verbs are signed events to the bridge's localhost listener.
#
#   bridge-ctl addrepo <name> <path> [category]
#                                      # create #<name> and map it to <path>.
#                                      # [category] files it under an existing
#                                      # category or creates a new one; omit to
#                                      # use the default inbox category
#   bridge-ctl start <name>            # start that repo's worker via the
#                                      # bridge (protocol injected, resumes)
#   bridge-ctl peek <name>             # post that worker's live screen into
#                                      # its channel (same as the 👀 reaction)
#   bridge-ctl rename <name> <label>   # rename that worker's Discord channel
#                                      # (display label only; mapping unchanged)
#   bridge-ctl repos                   # list channel -> repo mappings
#   bridge-ctl addguest <name> <discord_id> [edit|view]
#                                      # grant a guest edit (View+Send) or view
#                                      # (read-only) access to #<name>
#   bridge-ctl request <discord_id> <project> [summary]
#                                      # file an access request → approval card
#                                      # in #requests (used by the greeter)
#   bridge-ctl viewonly <name>|--all   # drop editors to view-only (one channel
#                                      # or everyone, everywhere) — instant
#   bridge-ctl revoke <name> <discord_id>   # remove a guest from #<name>
#   bridge-ctl guests                  # list guest access (edit/view per channel)
#
# addrepo prints the bridge's JSON response ({"status":"ok","channel_id":..})
# so callers can address the new channel immediately (e.g. with
# discord-notify -t discord:<channel_id>). start blocks until the worker is
# ready to receive agent-worker send.
set -uo pipefail

BRIDGE_CFG="${CLAUDE_WORKERS_BRIDGE_WEBHOOK_FILE:-${XDG_CONFIG_HOME:-$HOME/.config}/claude-workers/bridge-webhook}"
CONFIG="${CLAUDE_BRIDGE_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/claude-bridge/config.json}"

die() {
  echo "bridge-ctl: $*" >&2
  exit 1
}

post_event() { # post_event <json-body>; prints response
  local url secret sig
  [[ -r "$BRIDGE_CFG" ]] || die "no bridge credentials ($BRIDGE_CFG)"
  url="$(sed -n 's/^BRIDGE_WEBHOOK_URL=//p' "$BRIDGE_CFG" | head -1)"
  secret="$(sed -n 's/^BRIDGE_WEBHOOK_SECRET=//p' "$BRIDGE_CFG" | head -1)"
  [[ -n "$url" && -n "$secret" ]] || die "bridge credentials incomplete"
  sig="$(printf '%s' "$1" | SECRET="$secret" python3 -c '
import hashlib, hmac, os, sys
print(hmac.new(os.environ["SECRET"].encode(), sys.stdin.buffer.read(),
               hashlib.sha256).hexdigest())')" || die "signing failed"
  # -m 240: `start` holds the connection while the worker boots (up to ~3 min)
  curl -fsS -m 240 -H 'Content-Type: application/json' \
    -H "X-Webhook-Signature: $sig" -d "$1" "$url" \
    || die "bridge did not accept the request (is the service running?)"
  echo
}

cmd="${1:-}"
case "$cmd" in
  addrepo)
    name="${2:-}"
    path="${3:-}"
    category="${4:-}"
    [[ -n "$name" && -n "$path" ]] \
      || die "usage: bridge-ctl addrepo <name> <path> [category]"
    path="$(cd "${path/#\~/$HOME}" 2>/dev/null && pwd)" || die "no such directory: ${3}"
    body="$(NAME="$name" REPO="$path" CATEGORY="$category" python3 -c '
import json, os
req = {"event_type": "claude.bridge.addrepo",
       "name": os.environ["NAME"],
       "path": os.environ["REPO"]}
if os.environ.get("CATEGORY"):
    req["category"] = os.environ["CATEGORY"]
print(json.dumps(req))')" || die "could not build request"
    post_event "$body"
    ;;
  start)
    name="${2:-}"
    [[ -n "$name" ]] || die "usage: bridge-ctl start <name>"
    body="$(NAME="$name" python3 -c '
import json, os
print(json.dumps({"event_type": "claude.bridge.start",
                  "name": os.environ["NAME"]}))')" || die "could not build request"
    post_event "$body"
    ;;
  peek)
    name="${2:-}"
    [[ -n "$name" ]] || die "usage: bridge-ctl peek <name>"
    body="$(NAME="$name" python3 -c '
import json, os
print(json.dumps({"event_type": "claude.bridge.peek",
                  "name": os.environ["NAME"]}))')" || die "could not build request"
    post_event "$body"
    ;;
  rename)
    name="${2:-}"
    newname="${3:-}"
    [[ -n "$name" && -n "$newname" ]] \
      || die "usage: bridge-ctl rename <name> <new-channel-label>"
    body="$(NAME="$name" NEW="$newname" python3 -c '
import json, os
print(json.dumps({"event_type": "claude.bridge.rename",
                  "name": os.environ["NAME"],
                  "new_name": os.environ["NEW"]}))')" || die "could not build request"
    post_event "$body"
    ;;
  addguest)
    name="${2:-}"
    discord_id="${3:-}"
    access="${4:-edit}"
    [[ -n "$name" && -n "$discord_id" ]] \
      || die "usage: bridge-ctl addguest <name> <discord_id> [edit|view]"
    [[ "$discord_id" =~ ^[0-9]+$ ]] || die "discord_id must be numeric"
    [[ "$access" == edit || "$access" == view ]] \
      || die "access must be 'edit' or 'view'"
    body="$(NAME="$name" DID="$discord_id" ACC="$access" python3 -c '
import json, os
print(json.dumps({"event_type": "claude.bridge.addguest",
                  "name": os.environ["NAME"],
                  "discord_id": os.environ["DID"],
                  "access": os.environ["ACC"]}))')" || die "could not build request"
    post_event "$body"
    ;;
  request)
    discord_id="${2:-}"
    project="${3:-}"
    summary="${4:-}"
    [[ -n "$discord_id" && -n "$project" ]] \
      || die "usage: bridge-ctl request <discord_id> <project> [summary]"
    [[ "$discord_id" =~ ^[0-9]+$ ]] || die "discord_id must be numeric"
    body="$(DID="$discord_id" PROJ="$project" SUM="$summary" python3 -c '
import json, os
print(json.dumps({"event_type": "claude.bridge.request",
                  "discord_id": os.environ["DID"],
                  "project": os.environ["PROJ"],
                  "summary": os.environ["SUM"]}))')" || die "could not build request"
    post_event "$body"
    ;;
  viewonly)
    name="${2:-}"
    [[ -n "$name" ]] || die "usage: bridge-ctl viewonly <name>|--all"
    if [[ "$name" == "--all" ]]; then
      body='{"event_type": "claude.bridge.viewonly", "all": true}'
    else
      body="$(NAME="$name" python3 -c '
import json, os
print(json.dumps({"event_type": "claude.bridge.viewonly",
                  "name": os.environ["NAME"]}))')" || die "could not build request"
    fi
    post_event "$body"
    ;;
  revoke)
    name="${2:-}"
    discord_id="${3:-}"
    [[ -n "$name" && -n "$discord_id" ]] \
      || die "usage: bridge-ctl revoke <name> <discord_id>"
    [[ "$discord_id" =~ ^[0-9]+$ ]] || die "discord_id must be numeric"
    body="$(NAME="$name" DID="$discord_id" python3 -c '
import json, os
print(json.dumps({"event_type": "claude.bridge.revoke",
                  "name": os.environ["NAME"],
                  "discord_id": os.environ["DID"]}))')" || die "could not build request"
    post_event "$body"
    ;;
  guests)
    [[ -r "$CONFIG" ]] || die "no bridge config ($CONFIG)"
    python3 -c '
import json, sys
cfg = json.load(open(sys.argv[1]))
rows = [(r["name"], r.get("guests", []), r.get("viewers", []))
        for r in cfg.get("repos", {}).values()
        if r.get("guests") or r.get("viewers")]
if not rows:
    print("(no guest access granted)")
for name, editors, viewers in rows:
    e = ", ".join(str(g) for g in editors) or "-"
    v = ", ".join(str(g) for g in viewers) or "-"
    print(f"{name:<20} edit: {e:<28} view: {v}")' "$CONFIG"
    ;;
  repos)
    [[ -r "$CONFIG" ]] || die "no bridge config ($CONFIG)"
    python3 -c '
import json, sys
cfg = json.load(open(sys.argv[1]))
repos = cfg.get("repos", {})
if not repos:
    print("(no repo channels mapped)")
for cid, repo in repos.items():
    name, rdir = repo["name"], repo["dir"]
    print(f"{name:<20} discord:{cid}  {rdir}")' "$CONFIG"
    ;;
  ''|-h|--help|help)
    sed -n '2,29p' "$0" | sed 's/^# \{0,1\}//'
    ;;
  *)
    die "unknown command '$cmd' (addrepo, start, peek, rename, repos, addguest, request, viewonly, revoke, guests)"
    ;;
esac
