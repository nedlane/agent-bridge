{
  "permissions": {
    "allow": [
      "Bash(bridge-ctl repos)",
      "Bash(bridge-ctl request:*)"
    ],
    "deny": [
      "Edit",
      "Write",
      "NotebookEdit",
      "WebFetch",
      "WebSearch",
      "Task",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Bash(ncat:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Read(//home/nedlane/.ssh/**)",
      "Read(//home/nedlane/.config/**)",
      "Read(//home/nedlane/.claude/**)",
      "Read(//home/nedlane/dotfiles/**)"
    ],
    "defaultMode": "default"
  }
}
